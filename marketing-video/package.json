{
  "name": "quantfidelity-marketing-video",
  "version": "1.0.0",
  "private": true,
  "description": "Self-contained Remotion marketing video for QuantFidelity (separate from the main app).",
  "scripts": {
    "preview": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts QuantFidelityLaunchVideo out/quantfidelity-launch.mp4",
    "still": "remotion still src/index.ts QuantFidelityLaunchVideo out/frame.png --frame=120",
    "typecheck": "tsc --noEmit",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
