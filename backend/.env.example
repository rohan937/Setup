# QuantFidelity backend — example environment configuration.
# Copy to backend/.env and adjust for local development. Do NOT commit real secrets.
#
# M70 production notes:
#   - Set QF_ENVIRONMENT=production on your hosting platform (Render, etc.)
#   - Set QF_DATABASE_URL to your PostgreSQL connection string.
#     Render provides postgres:// URLs; the app normalises them to postgresql:// automatically.
#   - Generate a strong QF_JWT_SECRET_KEY: python3 -c "import secrets; print(secrets.token_hex(32))"
#   - Set QF_CORS_ORIGINS to your exact frontend origin (e.g. https://app.example.com).
#   - Set QF_DEBUG=false in production.

# Application
QF_APP_NAME=QuantFidelity
# Values: local | staging | production
QF_ENVIRONMENT=local
QF_DEBUG=true
QF_VERSION=0.1.0
QF_LOG_LEVEL=info

# Server — PORT is also read (without prefix) by Render's platform.
QF_HOST=0.0.0.0
QF_PORT=8000
# Alternatively, Render sets PORT directly; backend_start.sh uses ${PORT:-8000}.

# CORS — comma-separated list of allowed frontend origins.
# Production: set to exact deployed frontend URL, never use wildcard.
QF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# QF_CORS_ORIGINS=https://app.yourdomain.com

# Database
# Default: SQLite (no PostgreSQL required for local dev).
# Production: use a PostgreSQL URL. Render provides postgres:// — pasted as-is, app normalises it.
QF_DATABASE_URL=sqlite+pysqlite:///./quantfidelity.db
# PostgreSQL examples:
# QF_DATABASE_URL=postgresql+psycopg2://user:password@host:5432/quantfidelity
# QF_DATABASE_URL=postgres://user:password@host:5432/quantfidelity  (Render format — auto-normalised)

# M24: API Key authentication
# Set to true to require API keys for the evidence bundle ingestion endpoint.
# Recommended true in production if ingestion endpoint is publicly reachable.
QF_REQUIRE_API_KEY_FOR_INGESTION=false
# Optional: secret pepper for HMAC-SHA256 key hashing (stronger than plain SHA-256).
# Leave empty for local development. Set to a random secret in production.
QF_API_KEY_HASH_SECRET=
# API key prefix environment: "local" or "live"
QF_API_KEY_ENV=local

# M68: JWT / User Auth
QF_AUTH_ENABLED=true
# IMPORTANT: Replace with a strong random secret before ANY deployment.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
QF_JWT_SECRET_KEY=your-secret-key-here-do-not-use-default-in-production
QF_JWT_ALGORITHM=HS256
# Default: 10080 minutes (7 days). Increase for demo usage; lower for stricter security.
QF_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# M69: RBAC + Workspace/Project Access Control
# When true, workspace role (owner/admin/member/viewer) is enforced for
# authenticated callers. Requests with no bearer token remain permissive
# (local-dev pseudo-owner) so existing local flows keep working.
QF_RBAC_ENABLED=true

# M84: Transactional email (verification + password reset)
# Provider: "console" (default) prints emails — including verification/reset links —
# to the server log; no account needed (use for local dev). "resend" sends real email.
QF_EMAIL_PROVIDER=console
# Resend API key (secret). Required when QF_EMAIL_PROVIDER=resend. Never commit a real key.
QF_RESEND_API_KEY=
# Sender identity. In production the domain must be Resend-verified
# (or use the resend.dev test sender for staging).
QF_EMAIL_FROM=QuantFidelity <noreply@yourdomain.com>
# Optional: base URL for links in emails. If unset, QF_FRONTEND_URL is reused —
# leave unset to avoid duplicate config.
# QF_APP_FRONTEND_URL=https://app.yourdomain.com
# Link validity windows (hours).
QF_EMAIL_VERIFICATION_EXPIRE_HOURS=48
QF_PASSWORD_RESET_EXPIRE_HOURS=2

# M84: Invite-only registration
# When true, public registration is disabled (register endpoint returns 403).
# NOTE: invite-token issuance/redemption is not yet implemented, so enabling this
# currently blocks ALL public signup.
QF_INVITE_ONLY_REGISTRATION=false
