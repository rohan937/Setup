# QuantFidelity backend — example environment configuration.
# Copy to backend/.env and adjust for local development. Do NOT commit real secrets.

# Application
QF_APP_NAME=QuantFidelity
QF_ENVIRONMENT=local
QF_API_V1_PREFIX=/api/v1
QF_DEBUG=true

# Server
QF_HOST=0.0.0.0
QF_PORT=8000

# CORS — comma-separated list of allowed frontend origins
QF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# Default: SQLite (no PostgreSQL required for local dev).
# Uncomment and fill for PostgreSQL:
# QF_DATABASE_URL=postgresql+psycopg2://qf:qf@localhost:5432/quantfidelity
QF_DATABASE_URL=sqlite+pysqlite:///./quantfidelity.db

# M24: API Key authentication
# Set to true to require API keys for the evidence bundle ingestion endpoint
QF_REQUIRE_API_KEY_FOR_INGESTION=false
# Optional: secret pepper for HMAC-SHA256 key hashing (stronger than plain SHA-256)
# Leave empty for local development. Set to a random secret in production.
QF_API_KEY_HASH_SECRET=
# API key prefix environment: "local" or "live"
QF_API_KEY_ENV=local
