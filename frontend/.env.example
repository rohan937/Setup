# QuantFidelity frontend — example environment configuration.
# Copy to frontend/.env.local for local development. Do NOT commit .env.local or .env files.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
#
# M71 production notes:
#   - Set VITE_API_BASE_URL in your Vercel project environment variables.
#   - Point it at your Render backend URL after M70 backend deployment.
#   - Never commit real values to this file — use placeholder strings only.

# Backend API base URL — no trailing slash.
# Local dev:
VITE_API_BASE_URL=http://localhost:8000
# Production (set in Vercel dashboard, not here):
# VITE_API_BASE_URL=https://your-render-backend.onrender.com

# Application environment: local | staging | production
VITE_APP_ENV=local

# Demo mode — reserved for M73 public demo workspace.
# When true, the app may show read-only demo data without requiring login.
VITE_DEMO_MODE=false
